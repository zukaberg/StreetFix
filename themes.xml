<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Base.Theme.StreetFix" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:windowBackground">@color/colorBackground</item>
        <item name="colorPrimary">@color/nav_active</item>
        <item name="colorSecondary">@color/nav_active</item>
        <item name="colorSurface">@color/colorSurface</item>
        <item name="colorOnSurface">@color/colorOnSurface</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@color/colorSurface</item>
    </style>

    <style name="Theme.StreetFix" parent="Base.Theme.StreetFix" />

    <style name="Widget.App.Chip" parent="Widget.MaterialComponents.Chip.Choice">
        <item name="chipBackgroundColor">@color/chip_selector</item>
        <item name="android:textColor">@color/chip_text_selector</item>
        <item name="checkedIconVisible">false</item>
        <item name="chipStrokeWidth">0dp</item>
        <item name="rippleColor">@color/chip_bg_checked</item>
    </style>

    <style name="Widget.StreetFix.SurfaceButton" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="backgroundTint">@color/colorSurface</item>
        <item name="strokeColor">@color/border_color</item>
        <item name="strokeWidth">1dp</item>
        <item name="cornerRadius">14dp</item>
        <item name="android:textColor">@color/colorOnSurface</item>
        <item name="iconTint">@color/colorOnSurface</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
    </style>

</resources>